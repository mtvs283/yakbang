# Supabase (Phase 2.1 회원 시스템)
# 복사: cp .env.local.example .env.local  후 값 채우기

# 브라우저에 노출됨 (공개 키)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ⚠️ 서버 전용 — 절대 클라이언트/깃에 노출 금지
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# (선택) 배달 이메일 Edge Function용 — Supabase secrets로 설정 권장
# RESEND_API_KEY=re_xxx
# DELIVERY_FROM=약방광개토 <noreply@your-domain>
